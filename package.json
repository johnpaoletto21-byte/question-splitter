{
  "name": "question-cropper-v1",
  "version": "1.0.0",
  "private": true,
  "description": "Single-user local pipeline: PDF → rendered pages → crop → Drive upload",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "jest",
    "test:config": "jest --testPathPattern='adapters/config'",
    "test:source-model": "jest --testPathPattern='core/source-model'",
    "test:bootstrap": "jest --testPathPattern='core/run-orchestrator'",
    "test:pdf-renderer": "jest --testPathPattern='adapters/source-preparation/pdf-renderer'",
    "test:render-step": "jest --testPathPattern='core/run-orchestrator/__tests__/render-step'",
    "test:profile": "jest --testPathPattern='core/crop-target-profile'",
    "test:crop-engine": "jest --testPathPattern='core/crop-engine'",
    "test:output-composer": "jest --testPathPattern='core/output-composer'",
    "test:result-model": "jest --testPathPattern='core/result-model'",
    "test:composition-step": "jest --testPathPattern='core/run-orchestrator/__tests__/composition-step'",
    "test:upload-step": "jest --testPathPattern='core/run-orchestrator/__tests__/upload-step'",
    "test:drive-uploader": "jest --testPathPattern='adapters/upload/google-drive'",
    "test:prompt-store": "jest --testPathPattern='core/prompt-config-store'",
    "test:prompt-editor": "jest --testPathPattern='adapters/ui/local-app/__tests__/prompt-editor'",
    "preview": "tsc --project tsconfig.json && node dist/adapters/ui/local-app/preview-server.js",
    "app": "tsc --project tsconfig.json && node dist/adapters/ui/local-app/preview-server.js",
    "app:restart": "lsof -tiTCP:${PREVIEW_PORT:-3002} -sTCP:LISTEN | xargs -r kill && npm run app"
  },
  "devDependencies": {
    "@types/busboy": "^1.5.4",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "jest": "^29.7.0",
    "pdf-lib": "^1.17.1",
    "ts-jest": "^29.1.5",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "busboy": "^1.6.0",
    "canvas": "^3.2.3",
    "pdfjs-dist": "^3.11.174"
  }
}
